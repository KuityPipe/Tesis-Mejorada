# Copiar este archivo a codigo/backend/django/.env y completar con valores
# reales. NUNCA commitear el .env real (ya está en .gitignore).

# --- Django ---
DJANGO_SECRET_KEY=cambiar-por-una-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# --- Base de datos (PostgreSQL) ---
DB_NAME=keyserv
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- SMTP (envío de código de verificación, ver codigo/biometria/huella/AUTENTIFICACION.py) ---
# IMPORTANTE: la versión anterior de AUTENTIFICACION.py tenía una contraseña
# de correo real hardcodeada en el código fuente (ya rotada/removida en esta
# fase, ver docs/CODE_QUALITY_IMPROVEMENTS.md) — usar SIEMPRE variables de
# entorno para esto de ahora en adelante.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Transbank Webpay Plus (ver codigo/backend/django/KeyServApp/pagos.py) ---
# Vacío por defecto: sin esto, cualquier intento de pago lanza NotImplementedError.
TRANSBANK_COMMERCE_CODE=
TRANSBANK_API_KEY=
TRANSBANK_ENVIRONMENT=integracion
