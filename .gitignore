# Entornos virtuales
venv*/
*/venv/
fr-venv/
*/fr-venv/

# Python
__pycache__/
*.pyc
*.pyd

# Variables de entorno / secretos
.env

# Archivo de backup/export de GitHub (contiene datos personales, se deja fuera del tracking)
TesisAntigua/

# Cache regenerable (ej. texto extraído de PDFs para análisis) — no versionar
.sistema/cache/*
!.sistema/cache/.gitkeep

# Archivos subidos por usuarios (MEDIA_ROOT) — contenido en tiempo de ejecución,
# no código fuente; puede incluir datos personales (ej. CV/documentos subidos
# al probar la creación de publicaciones), nunca debe versionarse.
codigo/backend/django/media/
